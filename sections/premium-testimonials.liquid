<div class="reviews-section-wrapper">
  <!-- 1. ہیڈنگ سیکشن (لکیروں کے ساتھ) -->
  <div class="reviews-header">
    <h2 class="reviews-main-title"><span>{{ section.settings.heading }}</span></h2>
  </div>

  <!-- 2. ریویوز گرڈ / کنٹینرز -->
  <div class="reviews-grid">
    {%- for block in section.blocks -%}
      <div class="review-card-item">
        
        <!-- اوپر کا ڈارک نیوی بلو میسج ببل -->
        <div class="review-bubble">
          <!-- کوٹیشن مارک اور اسٹارز کی رو -->
          <div class="bubble-meta">
            <span class="quote-icon">“</span>
            <div class="star-rating">
              {%- assign stars = block.settings.rating | plus: 0 -%}
              {%- for i in (1..stars) -%}★{%- endfor -%}
            </div>
          </div>
          <!-- کسٹمر کا میسج -->
          <p class="review-text">{{ block.settings.review_text }}</p>
        </div>

        <!-- نیچے کسٹمر کی پروفائل (تصویر، نام اور تاریخ) -->
        <div class="customer-profile-wrap">
          <div class="customer-avatar">
            {%- if block.settings.customer_image != blank -%}
              <img src="{{ block.settings.customer_image | img_url: '100x100', crop: 'center' }}" alt="{{ block.settings.customer_name }}">
            {%- else -%}
              <!-- اگر تصویر نہ ہو تو نام کا پہلا حرف دکھانے کے لیے -->
              <div class="avatar-placeholder">{{ block.settings.customer_name | slice: 0 | upcase }}</div>
            {%- endif -%}
          </div>
          <div class="customer-meta-info">
            <h4 class="customer-name">{{ block.settings.customer_name }}</h4>
            <span class="review-date">{{ block.settings.review_date }}</span>
          </div>
        </div>

      </div>
    {%- endfor -%}
  </div>

  <!-- سلائیڈر ڈاٹس (ڈیزائن میچنگ کے لیے) -->
  <div class="reviews-carousel-dots">
    <span class="dot active"></span>
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot"></span>
    <span class="dot"></span>
  </div>
</div>

<style>
/* مین ریپر */
.reviews-section-wrapper {
  padding: 60px 20px;
  max-width: 1240px;
  margin: 0 auto;
  font-family: Arial, sans-serif;
}

/* ہیڈنگ ڈیزائن لکیروں کے ساتھ */
.reviews-header {
  text-align: center;
  margin-bottom: 45px;
}
.reviews-main-title {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  letter-spacing: 3px;
  color: #333;
  text-transform: uppercase;
  font-weight: 500;
}
.reviews-main-title::before, .reviews-main-title::after {
  content: "";
  flex: 0 1 120px;
  border-bottom: 1px solid #999;
}
.reviews-main-title span {
  padding: 0 20px;
}

/* 3 کالم گرڈ لے آؤٹ */
.reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
}

/* میسج ببل (ڈارک نیوی بلو باکس) */
.review-bubble {
  background: #040943; /* تصویر والا اصل گہرا نیلا رنگ */
  color: #ffffff;
  padding: 30px;
  border-radius: 4px;
  position: relative;
  min-height: 180px;
  box-sizing: border-box;
}

/* ببل کے نیچے والی تکون نوک (Triangle Arrow) */
.review-bubble::after {
  content: "";
  position: absolute;
  bottom: -15px;
  left: 45px; /* تصویر کے مطابق بالکل بائیں کسٹمر تصویر کے اوپر الائنڈ */
  width: 0;
  height: 0;
  border-left: 15px solid transparent;
  border-right: 15px solid transparent;
  border-top: 15px solid #040943;
}

/* کوٹیشن مارک اور اسٹارز کی سیٹنگ */
.bubble-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 15px;
}
.quote-icon {
  font-size: 42px;
  font-family: Georgia, serif;
  line-height: 1;
  color: #ffffff;
  opacity: 0.6;
}
.star-rating {
  color: #ffcc00; /* چمکدار پیلا رنگ ستاروں کے لیے */
  font-size: 16px;
  letter-spacing: 2px;
}

/* ریویو ٹیکسٹ کا اسٹائل */
.review-text {
  font-size: 13.5px;
  line-height: 1.6;
  margin: 0;
  color: #f1f1f1;
  font-weight: 400;
  text-align: left;
}

/* کسٹمر پروفائل کا لے آؤٹ */
.customer-profile-wrap {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-top: 30px; /* ببل سے مناسب فاصلہ */
  padding-left: 20px;
}

/* گول کسٹمر تصویر */
.customer-avatar {
  width: 55px;
  height: 55px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}
.customer-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* اگر کسٹمر کی امیج اپلوڈ نہ ہو تو یہ خوبصورت سالڈ بیک گراؤنڈ سرکل دکھائے گا */
.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: #0e6251; /* جیسے تصویر میں لیفٹ سائیڈ پر سبز اور نیلے رنگ کے دائرے ہیں */
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 20px;
}

/* کسٹمر کا نام اور تاریخ */
.customer-meta-info {
  text-align: left;
}
.customer-name {
  font-size: 12px;
  font-weight: bold;
  color: #222;
  margin: 0 0 4px 0;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.review-date {
  font-size: 11px;
  color: #666;
  text-transform: uppercase;
}

/* نیچے والے ڈاٹس کا فلیٹ ڈیزائن */
.reviews-carousel-dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 40px;
}
.reviews-carousel-dots .dot {
  width: 8px;
  height: 8px;
  border: 1px solid #bbb;
  border-radius: 50%;
  display: inline-block;
}
.reviews-carousel-dots .dot.active {
  background: #bbb;
}

/* موبائل اسکرین ریسپونسیوٹی */
@media (max-width: 991px) {
  .reviews-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 768px) {
  .reviews-grid {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "Premium Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "WHAT OUR CUSTOMERS SAY"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Customer Review",
      "settings": [
        {
          "type": "select",
          "id": "rating",
          "label": "Stars Rating",
          "options": [
            { "value": "5", "label": "5 Stars" },
            { "value": "4", "label": "4 Stars" },
            { "value": "3", "label": "3 Stars" }
          ],
          "default": "5"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Customer Review Text",
          "default": "Ordered a custom tote bag recently and their service was amazing from prompt replies to delivering the product on time. I'm very happy!"
        },
        {
          "type": "image_picker",
          "id": "customer_image",
          "label": "Customer Avatar (Image)"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer Name",
          "default": "ENURI LIYARA"
        },
        {
          "type": "text",
          "id": "review_date",
          "label": "Review Date",
          "default": "11 APR 2025"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Testimonials",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}