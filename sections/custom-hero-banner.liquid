<div class="custom-hero-banner" id="HeroBanner-{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <img src="{{ section.settings.image | img_url: '1600x' }}" alt="{{ section.settings.heading }}" class="hero-bg-img" loading="lazy">
  {%- else -%}
    <div class="hero-placeholder-bg"></div>
  {%- endif -%}

  <div class="hero-overlay-content">
    {%- if section.settings.subheading != blank -%}
      <p class="hero-subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="hero-heading">
        {%- assign words = section.settings.heading | split: ' ' -%}
        {%- for word in words -%}
          {%- if forloop.first -%}
            <span class="hero-blue-text">{{ word }}</span>
          {%- else -%}
            {{ word }}
          {%- endif -%}
        {%- endfor -%}
      </h2>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <a href="{{ section.settings.button_link }}" class="hero-outline-btn">
        {{ section.settings.button_text }} &rarr;
      </a>
    {%- endif -%}
  </div>
</div>

<style>
.custom-hero-banner {
  position: relative;
  width: 100%;
  height: 380px; /* تصویر کے حساب سے اونچائی ایڈجسٹ کی گئی ہے */
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
  filter: brightness(0.65); /* تصویر کو تھوڑا ڈارک کیا ہے تاکہ ٹیکسٹ واضح نظر آئے */
}

.hero-placeholder-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #333;
  z-index: 1;
}

.hero-overlay-content {
  position: relative;
  z-index: 2;
  text-align: center;
  color: #ffffff;
  padding: 0 20px;
  max-width: 800px;
}

/* Permanent print mugs والا ٹیکسٹ */
.hero-subheading {
  font-family: 'Georgia', serif;
  font-style: italic;
  font-size: 22px;
  margin: 0 0 10px 0;
  letter-spacing: 1px;
  color: #ffffff;
}

/* مین ہیڈنگ */
.hero-heading {
  font-family: 'Montserrat', 'Arial Black', sans-serif;
  font-size: 42px;
  font-weight: 900;
  line-height: 1.2;
  text-transform: uppercase;
  margin: 0 0 25px 0;
  letter-spacing: 2px;
  color: #ffffff;
}

/* پہلے لفظ (Customize) کو نیلے رنگ میں دکھانے کے لیے */
.hero-blue-text {
  color: #004fc6; /* تصویر والا پرفیکٹ بلیو کلر */
}

/* آؤٹ لائن والا بٹن */
.hero-outline-btn {
  display: inline-block;
  background: transparent;
  color: #ffffff;
  border: 1px solid #ffffff;
  padding: 12px 35px;
  font-size: 13px;
  font-weight: bold;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 1px;
  transition: all 0.3s ease;
}

.hero-outline-btn:hover {
  background: #ffffff;
  color: #000000;
}

/* موبائل اسکرین کے لیے سیٹنگز */
@media (max-width: 768px) {
  .custom-hero-banner {
    height: 300px;
  }
  .hero-heading {
    font-size: 28px;
  }
  .hero-subheading {
    font-size: 18px;
  }
}
</style>

{% schema %}
{
  "name": "Custom Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (Italic Text)",
      "default": "Permanent print mugs"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Main Heading",
      "default": "CUSTOMIZE AS PER YOUR LIKING"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "PURCHASE NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero Banner"
    }
  ]
}
{% endschema %}