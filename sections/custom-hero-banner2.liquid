<div class="custom-hero-banner">
  <div class="hero-image-container">
    {% if section.settings.bg_image != blank %}
      <img src="{{ section.settings.bg_image | img_url: '1600x' }}" alt="Banner Image">
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  </div>

  <div class="hero-overlay-content">
    <div class="content-box">
      <h2 class="hero-title">{{ section.settings.title }}</h2>
      <p class="hero-subtitle">{{ section.settings.subtitle }}</p>
      {% if section.settings.btn_label != blank %}
        <a href="{{ section.settings.btn_link }}" class="hero-btn">{{ section.settings.btn_label }} →</a>
      {% endif %}
    </div>
  </div>
</div>

<style>
.custom-hero-banner {
  position: relative;
  width: 100%;
  height: 450px; /* آپ اپنی ضرورت کے مطابق اونچائی بدل سکتے ہیں */
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-image-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.hero-image-container img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* تصویر کے اوپر والا دھندلا ڈبہ (Overlay Box) */
.hero-overlay-content {
  position: relative;
  z-index: 2;
  text-align: center;
  width: 100%;
  max-width: 600px;
  padding: 20px;
}

.content-box {
  background: rgba(0, 0, 0, 0.5); /* کالا ٹرانسپیرنٹ رنگ */
  padding: 40px;
  border-radius: 2px;
  backdrop-filter: blur(5px); /* ہلکا سا دھندلا اثر */
}

.hero-title {
  color: #ffffff;
  font-size: 32px;
  font-weight: bold;
  margin-bottom: 15px;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.hero-subtitle {
  color: #f1f1f1;
  font-size: 16px;
  margin-bottom: 25px;
  line-height: 1.5;
}

.hero-btn {
  display: inline-block;
  padding: 12px 30px;
  border: 1px solid #ffffff;
  color: #ffffff;
  text-decoration: none;
  font-size: 14px;
  text-transform: uppercase;
  transition: 0.3s;
}

.hero-btn:hover {
  background: #ffffff;
  color: #000;
}

/* موبائل کے لیے سیٹنگ */
@media (max-width: 768px) {
  .custom-hero-banner { height: 350px; }
  .hero-title { font-size: 24px; }
  .content-box { padding: 20px; margin: 10px; }
}
</style>

{% schema %}
{
  "name": "Image with Text Overlay",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Mugshot LK"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sub-text",
      "default": "We deliver islandwide. Orders delivered in 3-7 working days."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "PURCHASE NOW"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Image with Text Overlay"
    }
  ]
}
{% endschema %}