<div class="printing-guide-wrapper">
  <!-- 1. مین ہیڈنگ لکیروں کے ساتھ -->
  <div class="guide-header">
    <h2 class="guide-main-title"><span>{{ section.settings.heading }}</span></h2>
  </div>

  <!-- 2. ٹیکسٹ کنٹینٹ ایریا -->
  <div class="guide-content-body">
    <p class="guide-paragraph-main">
      {{ section.settings.main_text }}
    </p>

    <h3 class="guide-sub-heading">{{ section.settings.sub_heading_1 }}</h3>
    <p class="guide-paragraph">
      {{ section.settings.sub_text_1 }}
    </p>

    <h3 class="guide-sub-heading">{{ section.settings.sub_heading_2 }}</h3>
    <p class="guide-paragraph">
      {{ section.settings.sub_text_2 }}
    </p>
  </div>

  <!-- 3. شو مور بٹن -->
  <div class="guide-action-area">
    {% if section.settings.btn_label != blank %}
      <a href="{{ section.settings.btn_link }}" class="guide-show-more-btn">{{ section.settings.btn_label }}</a>
    {% endif %}
  </div>
</div>

<style>
/* مین کنٹینر ریپر */
.printing-guide-wrapper {
  padding: 60px 20px;
  max-width: 1240px;
  margin: 0 auto;
  font-family: 'Assistant', sans-serif; /* شاپیفائی کا سٹینڈرڈ کلین فونٹ */
}

/* ہیڈنگ کا اسٹائل سائیڈ لائنز کے ساتھ */
.guide-header {
  text-align: center;
  margin-bottom: 40px;
}
.guide-main-title {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  letter-spacing: 1px;
  color: #4a4a4a;
  font-weight: 400;
  margin: 0;
}
.guide-main-title::before, .guide-main-title::after {
  content: "";
  flex: 0 1 70px; /* لکیروں کی لمبائی */
  border-bottom: 1px solid #333;
}
.guide-main-title span {
  padding: 0 20px;
}

/* ٹیکسٹ کی باڈی اور سپیسنگ */
.guide-content-body {
  max-width: 1180px;
  margin: 0 auto;
  text-align: left;
}

.guide-paragraph-main {
  font-size: 15px;
  line-height: 1.7;
  color: #333333;
  margin-bottom: 25px;
  font-weight: 400;
}

/* سب ہیڈنگز کا رنگ اور فونٹ سائز */
.guide-sub-heading {
  font-size: 19px;
  color: #2b4560; /* تصویر کے مطابق ہلکا سا نیلگوں گہرا رنگ */
  margin: 25px 0 12px 0;
  font-weight: 500;
}

.guide-paragraph {
  font-size: 15px;
  line-height: 1.6;
  color: #4a4a4a;
  margin-bottom: 20px;
}

/* بٹن کی الائنمنٹ اور ڈیزائن */
.guide-action-area {
  text-align: center;
  margin-top: 40px;
}

.guide-show-more-btn {
  display: inline-block;
  padding: 12px 45px;
  border: 1px solid #000000;
  background: #ffffff;
  color: #000000;
  text-decoration: none;
  font-size: 14px;
  font-weight: 400;
  transition: all 0.3s ease;
}

/* بٹن ہوور ایفیکٹ */
.guide-show-more-btn:hover {
  background: #000000;
  color: #ffffff;
}

/* موبائل اسکرین سیٹنگز */
@media (max-width: 768px) {
  .guide-main-title {
    font-size: 18px;
  }
  .guide-main-title::before, .guide-main-title::after {
    flex: 0 1 30px; /* موبائل پر لکیریں چھوٹی ہو جائیں گی */
  }
  .guide-paragraph-main, .guide-paragraph {
    font-size: 14px;
    text-align: justify; /* موبائل پر ٹیکسٹ دونوں سائیڈ سے برابر لگے گا */
  }
  .guide-sub-heading {
    font-size: 17px;
  }
}
</style>

{% schema %}
{
  "name": "Digital Printing Guide",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "A Guide To Digital Printing- Learn With Mugshot"
    },
    {
      "type": "textarea",
      "id": "main_text",
      "label": "Main Paragraph",
      "default": "The world of printing is fascinating but it can get complex when it comes to the types. If you are having second thoughts about digital printing then let's have a look at how it's done in detail. With Mugshot you can learn the art of digital printing so when you demand a print yourself you know the ways we use it. Stay with us till the end and you'll know everything you must about this printing. From finding the right colors to get the printed products at affordable rates let's explore everything."
    },
    {
      "type": "text",
      "id": "sub_heading_1",
      "label": "Sub Heading 1",
      "default": "What is Digital Printing?"
    },
    {
      "type": "textarea",
      "id": "sub_text_1",
      "label": "Sub Paragraph 1",
      "default": "In digital printing, we print digital based images directly onto a variety of media substrates by using minute droplets of ink that transfers the image onto it."
    },
    {
      "type": "text",
      "id": "sub_heading_2",
      "label": "Sub Heading 2",
      "default": "Types of Digital Printing"
    },
    {
      "type": "textarea",
      "id": "sub_text_2",
      "label": "Sub Paragraph 2",
      "default": "There are many forms of digital printing. Some of the famous ones are:"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Show More"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Digital Printing Guide"
    }
  ]
}
{% endschema %}